<div class="container py-4">
  <h2>タスク一覧</h2>

  <table class="table">
    <thead>
      <tr>
        <th>タイトル</th>
        <th>開始日</th>
        <th>終了日</th>
        <th>重要度</th>
        <th>緊急度</th>
        <th>ステータス</th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= link_to task.title, task_path(task) %></td>
          <td><%= task.start_time %></td>
          <td><%= task.end_time %></td>
          <td><%= task.importance %></td>
          <td><%= task.urgency %></td>
          <td><%= task.status %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>